# Server-side configuration.
# Copy to deploy/biorxiv-mcp.env and edit. The systemd unit loads it.

# Bind address and port. Default 127.0.0.1 assumes a reverse proxy in front.
HOST=127.0.0.1
PORT=8000

# Comma-separated CORS origins.
CORS_ORIGINS=*

# API keys (comma-separated). When set, /api/* requires Authorization: Bearer.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# BIORXIV_MCP_API_KEYS=key1,key2

# Keys that bypass rate limiting (implicitly valid, no need to also list above).
# BIORXIV_MCP_UNLIMITED_KEYS=my-personal-key

# Per-key rate limit.
# BIORXIV_MCP_KEY_RATE=1.0
# BIORXIV_MCP_KEY_BURST=60

# Proxy IPs trusted for X-Forwarded-For.
FORWARDED_ALLOW_IPS=127.0.0.1

# Log level.
LOG_LEVEL=INFO

# Database directory.
# BIORXIV_MCP_DATA=/var/lib/biorxiv-mcp

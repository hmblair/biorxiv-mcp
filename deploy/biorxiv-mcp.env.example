# Server-side configuration.
# Copy to deploy/biorxiv-mcp.env and edit. The systemd unit loads it.

# Bind address and port. Default 127.0.0.1 assumes a reverse proxy in front.
HOST=127.0.0.1
PORT=8000

# Comma-separated CORS origins.
CORS_ORIGINS=*

# API keys are managed via the database, not env vars:
#   biorxiv-mcp-server keys add --label <name> [--unlimited]
#   biorxiv-mcp-server keys list
#   biorxiv-mcp-server keys revoke <key_id>
# No restart required.

# Per-key rate limit (applies to non-unlimited keys).
# BIORXIV_MCP_KEY_RATE=1.0
# BIORXIV_MCP_KEY_BURST=60

# Proxy IPs trusted for X-Forwarded-For.
FORWARDED_ALLOW_IPS=127.0.0.1

# Log level.
LOG_LEVEL=INFO

# Database directory.
# BIORXIV_MCP_DATA=/var/lib/biorxiv-mcp

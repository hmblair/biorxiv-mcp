# Copy to deploy/biorxiv-mcp.env and edit for your deployment.
# The systemd unit loads this file if present.

# Bind address and port for the HTTP transport. Default 127.0.0.1 assumes
# a reverse proxy (Caddy, cloudflared, nginx) in front. Use 0.0.0.0 only
# when the server is itself the public entry point.
HOST=127.0.0.1
PORT=8000

# Transport: "http" (streamable HTTP) or "stdio".
TRANSPORT=http

# Comma-separated CORS origins. Use "*" for any (not recommended on public
# networks). For a single-origin browser client, set e.g.:
#   CORS_ORIGINS=https://my.app
CORS_ORIGINS=*

# Comma-separated API keys. When set, all /mcp requests must send
#   Authorization: Bearer <key>
# Generate keys with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave unset for local/stdio use (requests are unauthenticated, with a
# per-IP rate limit applied as a weak abuse deterrent).
# BIORXIV_MCP_API_KEYS=key1,key2,key3

# Per-key request budget (tokens/sec, bucket size).
# BIORXIV_MCP_KEY_RATE=1.0
# BIORXIV_MCP_KEY_BURST=60

# Per-IP budget used when no API keys are configured.
# BIORXIV_MCP_ANON_RATE=0.5
# BIORXIV_MCP_ANON_BURST=30

# Proxy IPs permitted to set X-Forwarded-For. 127.0.0.1 is correct for
# Caddy/cloudflared running on the same host.
FORWARDED_ALLOW_IPS=127.0.0.1

# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Override the database/papers directory.
# BIORXIV_MCP_DATA=/var/lib/biorxiv-mcp
